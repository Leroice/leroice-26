---
import Base from '../../layouts/Base.astro';
import { getCollection, render } from 'astro:content';

export async function getStaticPaths() {
  const entries = await getCollection('work', ({ data }) => data.detail === true);
  return entries.map((entry) => ({
    params: { slug: entry.id.replace(/\.md$/, '') },
    props: { entry },
  }));
}

const { entry } = Astro.props;
const { Content } = await render(entry);
---

<Base title={`${entry.data.title} — Leigh Scholten`} description={entry.data.summary}>
  <section class="detail__subnav" data-reveal>
    <div class="detail__subnav-inner">
      <a href="/" class="detail__subnav-title" aria-label="Back to work list">
        <span class="detail__subnav-name">{entry.data.title}</span>
        <span class="detail__subnav-meta">{entry.data.context}</span>
      </a>
      <nav class="detail__subnav-tabs" aria-label="Page sections">
        <a href="#details">Details</a>
        <a href="#credits">Credits</a>
      </nav>
    </div>
  </section>

  <article class="detail">
    {entry.data.cover && (
      <img
        class="detail__hero" data-reveal
        src={entry.data.cover}
        alt={entry.data.coverAlt ?? entry.data.title}
      />
    )}

    <div class="detail__body" id="details" data-reveal-children>
      <Content />
    </div>
  </article>
</Base>
