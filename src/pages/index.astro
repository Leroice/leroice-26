---
import Base from '../layouts/Base.astro';
import { getCollection, render } from 'astro:content';

const entries = (await getCollection('work')).sort(
  (a, b) => a.data.order - b.data.order
);

const slug = (id: string) => id.replace(/\.md$/, '');

// Every project with a detail page opens inline with the choreographed
// transition (cover image flies into the header, title rises, proximity
// cascade). They each have a real /work/[slug] page as a deep-link fallback.
const inlineSlugs = new Set(
  entries.filter((e) => e.data.detail).map((e) => slug(e.id))
);

const inlineEntries = await Promise.all(
  entries
    .filter((e) => inlineSlugs.has(slug(e.id)))
    .map(async (entry) => {
      const { Content } = await render(entry);
      return { entry, Content };
    })
);
---

<Base
  title="Leigh Scholten"
  description="Designer based in Melbourne. Currently working on Western Union's AU digital wallet."
>
  <main class="split">
    <section class="list" data-list>
      <div class="list__pill-wrap">
        <div class="list__pill" data-pill></div>
      </div>

      {entries.map((entry, i) => {
        const isInline = inlineSlugs.has(slug(entry.id));
        const href = isInline
          ? null
          : (entry.data.external
            ?? (entry.data.detail ? `/work/${slug(entry.id)}` : null));

        const Tag = href ? 'a' : 'div';
        const extra = entry.data.external
          ? { href, rel: 'noopener', target: '_blank' }
          : href ? { href } : {};
        // Inline rows are <div>s (no href), so make them keyboard-operable.
        const inlineAttrs = isInline
          ? {
              'data-inline': 'true',
              role: 'button',
              tabindex: '0',
              'aria-label': `Open ${entry.data.title} case study`,
            }
          : {};

        return (
          <Tag
            class="row"
            data-row
            data-reveal
            data-slug={slug(entry.id)}
            data-index={i}
            {...extra}
            {...inlineAttrs}
          >
            <div class="row__inner">
              <div class="row__year">{entry.data.year}</div>
              <div class="row__title">{entry.data.title}</div>
              <div class="row__desc">{entry.data.context}</div>
            </div>

            {entry.data.cover && (
              <div class="row__media">
                <img
                  src={entry.data.cover}
                  alt={entry.data.coverAlt ?? entry.data.title}
                  loading="lazy"
                />
              </div>
            )}
          </Tag>
        );
      })}

      {inlineEntries.map(({ entry, Content }) => (
        <div class="list__detail" data-detail-slug={slug(entry.id)} hidden>
          <button class="detail__back" type="button" data-detail-back>← back</button>
          {entry.data.cover && (
            <img
              class="detail__hero"
              src={entry.data.cover}
              alt={entry.data.coverAlt ?? entry.data.title}
            />
          )}
          <div class="detail__body">
            <Content />
          </div>
        </div>
      ))}
    </section>

    <aside class="preview" aria-hidden="true">
      <div class="preview__frame" data-preview-frame>
        {entries
          .filter((e) => e.data.cover)
          .map((entry) => (
            <img
              class="preview__image"
              data-preview-image={slug(entry.id)}
              src={entry.data.cover}
              alt=""
              loading="eager"
            />
          ))
        }
      </div>
    </aside>
  </main>

  {/* TUNING — live design tool for the list→detail choreography.
      Sandbox-only: gate or remove before promoting to the real domain. */}
  <button class="tuner-toggle" type="button" data-tuner-toggle aria-expanded="false">TUNING</button>
  <aside class="tuner" data-tuner hidden aria-label="Transition tuning">
    <header class="tuner__head">
      <span>transition tuning</span>
      <span class="tuner__status" data-tune-status></span>
    </header>
    <div class="tuner__grid">
      <label><span class="tuner__lab">Lead-in <output id="out-leadIn"></output></span><input type="range" id="tune-leadIn" /></label>
      <label><span class="tuner__lab">Title duration <output id="out-tdur"></output></span><input type="range" id="tune-tdur" /></label>
      <label><span class="tuner__lab">Image duration <output id="out-idur"></output></span><input type="range" id="tune-idur" /></label>
      <label><span class="tuner__lab">Image delay (trail) <output id="out-idelay"></output></span><input type="range" id="tune-idelay" /></label>
      <label><span class="tuner__lab">Image arc (yield) <output id="out-iarc"></output></span><input type="range" id="tune-iarc" /></label>
      <label><span class="tuner__lab">Min yield <output id="out-iyield"></output></span><input type="range" id="tune-iyield" /></label>
      <label><span class="tuner__lab">Cascade step <output id="out-sgstep"></output></span><input type="range" id="tune-sgstep" /></label>
      <label><span class="tuner__lab">Cascade blur <output id="out-sgblur"></output></span><input type="range" id="tune-sgblur" /></label>
      <label><span class="tuner__lab">Easing</span>
        <select id="tune-easing"></select>
      </label>
    </div>

    <div class="tuner__spring" data-tuner-spring>
      <div class="tuner__sub">spring (when easing = spring)</div>
      <label><span class="tuner__lab">Stiffness <output id="out-sstiff"></output></span><input type="range" id="tune-sstiff" /></label>
      <label><span class="tuner__lab">Damping <output id="out-sdamp"></output></span><input type="range" id="tune-sdamp" /></label>
      <label><span class="tuner__lab">Mass <output id="out-smass"></output></span><input type="range" id="tune-smass" /></label>
    </div>
    <div class="tuner__actions">
      <button type="button" data-tune-replay>Replay</button>
      <button type="button" data-tune-copy>Copy</button>
      <button type="button" data-tune-reset>Reset</button>
    </div>
  </aside>
</Base>

<script>
  // ─────────────────────────────────────────────────────────
  // Pill — fast spring to target row.
  // Gooey SVG filter (defined in Base layout) handles the liquid
  // silhouette automatically; no manual deformation needed in JS.
  // ─────────────────────────────────────────────────────────

  const list = document.querySelector('[data-list]') as HTMLElement | null;
  const pill = document.querySelector('[data-pill]') as HTMLElement | null;
  const images = Array.from(document.querySelectorAll<HTMLImageElement>('[data-preview-image]'));
  const rows = Array.from(document.querySelectorAll<HTMLElement>('[data-row]'));

  const prefersReduced = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
  const isTouch = window.matchMedia('(hover: none)').matches;

  if (list && pill && rows.length && !isTouch && !prefersReduced) {

    const readMotion = () => {
      const cs = getComputedStyle(document.documentElement);
      const n = (name: string, fallback: number) =>
        parseFloat(cs.getPropertyValue(name)) || fallback;
      return {
        stiffness:           n('--spring-stiffness',          410),
        damping:             n('--spring-damping',            84),
        mass:                n('--spring-mass',               3),
        // Velocity-driven pill breath
        breathPeakVelocity:  n('--pill-breath-peak-velocity', 2000),
        breathBlurMax:       n('--pill-breath-blur-max',      16),
        opacityRest:         n('--pill-opacity-rest',         0.06),
        opacityMoving:       n('--pill-opacity-moving',       0.03),
        // Velocity-driven frame breath (same signal as pill, different mapping)
        frameBlurMax:        n('--frame-blur-max',            7),
        frameOpacityMin:     n('--frame-opacity-min',         0.6),
        frameScaleMin:       n('--frame-scale-min',           0.95),
      };
    };

    const state = {
      y: 0,
      h: 0,
      targetY: 0,
      targetH: 0,
      vy: 0,
      vh: 0,
    };

    // Slug queued for swap on next high-velocity frame
    // (transition state declared below, near step())

    let activeRow: HTMLElement | null = null;
    let rafId = 0;
    let lastTs = 0;

    const measureRow = (row: HTMLElement) => {
      const listRect = list.getBoundingClientRect();
      const rowRect = row.getBoundingClientRect();
      return {
        y: rowRect.top - listRect.top,
        h: rowRect.height,
      };
    };

    // Park pill on first row at rest
    if (rows[0]) {
      const { y, h } = measureRow(rows[0]);
      state.y = state.targetY = y;
      state.h = state.targetH = h;
      pill.style.transform = `translateY(${y}px)`;
      pill.style.height = `${h}px`;
      // Note: no row is .is-active by default. All rows render at 90% opacity
      // until the user hovers one, matching the "empty until hover" preview
      // behaviour established earlier.
    }

    // Track transition for cross-fade between two images during spring travel
    let outgoingSlug: string | null = null;
    let incomingSlug: string | null = null;
    let transitionStartY = 0;
    let transitionDistance = 0;

    const step = (dt: number) => {
      const m = readMotion();
      const stepDt = Math.min(dt, 1 / 30);

      const fy = -m.stiffness * (state.y - state.targetY) - m.damping * state.vy;
      state.vy += (fy / m.mass) * stepDt;
      state.y  += state.vy * stepDt;

      const fh = -m.stiffness * (state.h - state.targetH) - m.damping * state.vh;
      state.vh += (fh / m.mass) * stepDt;
      state.h  += state.vh * stepDt;

      pill.style.transform = `translateY(${state.y.toFixed(2)}px)`;
      pill.style.height = `${state.h}px`;

      // ── Velocity-driven blur (the breath texture) ──
      const speed = Math.hypot(state.vy, state.vh);
      const velocityNorm = Math.min(speed / m.breathPeakVelocity, 1);

      const pillBlur    = velocityNorm * m.breathBlurMax;
      const pillOpacity = m.opacityRest - (velocityNorm * (m.opacityRest - m.opacityMoving));
      const frameBlur   = velocityNorm * m.frameBlurMax;

      const docStyle = document.documentElement.style;
      docStyle.setProperty('--pill-velocity-blur', `${pillBlur.toFixed(2)}px`);
      docStyle.setProperty('--pill-velocity-opacity', pillOpacity.toFixed(3));
      docStyle.setProperty('--frame-blur', `${frameBlur.toFixed(2)}px`);

      // ── Progress-driven cross-fade between outgoing and incoming images ──
      // Progress is how far we've traveled toward the target as a fraction of
      // total distance. Continuous through the whole motion — not a "swap event".
      if (incomingSlug !== null && transitionDistance > 0.5) {
        const traveled = Math.abs(state.y - transitionStartY);
        const progress = Math.min(traveled / transitionDistance, 1);

        // Smooth progress through a small ease so the cross-fade is the spring's curve
        // (the spring is doing the easing on y; mapping y to opacity is linear).
        images.forEach((img) => {
          if (img.dataset.previewImage === incomingSlug) {
            img.style.opacity = String(progress);
          } else if (img.dataset.previewImage === outgoingSlug) {
            img.style.opacity = String(1 - progress);
          }
        });
      }

      const settled =
        Math.abs(state.y - state.targetY) < 0.1 &&
        Math.abs(state.h - state.targetH) < 0.1 &&
        Math.abs(state.vy) < 1.0 &&
        Math.abs(state.vh) < 1.0;

      if (settled) {
        state.y = state.targetY;
        state.h = state.targetH;
        state.vy = 0;
        state.vh = 0;
        pill.style.transform = `translateY(${state.y}px)`;
        pill.style.height = `${state.h}px`;
        docStyle.setProperty('--pill-velocity-blur', '0px');
        docStyle.setProperty('--pill-velocity-opacity', String(m.opacityRest));
        docStyle.setProperty('--frame-blur', '0px');

        // Finalise the cross-fade — incoming = 1, outgoing = 0, class state authoritative.
        if (incomingSlug !== null) {
          images.forEach((img) => {
            const isIncoming = img.dataset.previewImage === incomingSlug;
            img.classList.toggle('is-active', isIncoming);
            img.style.opacity = ''; // clear inline opacity; let CSS class handle rest state
          });
          outgoingSlug = null;
          incomingSlug = null;
        }
        return false;
      }
      return true;
    };

    const tick = (ts: number) => {
      const dt = lastTs ? (ts - lastTs) / 1000 : 1 / 60;
      lastTs = ts;
      if (step(dt)) {
        rafId = requestAnimationFrame(tick);
      } else {
        rafId = 0;
        lastTs = 0;
      }
    };

    const ensureRaf = () => {
      if (!rafId) {
        lastTs = 0;
        rafId = requestAnimationFrame(tick);
      }
    };

    const setActive = (row: HTMLElement) => {
      if (row === activeRow) return;

      // Toggle .is-active on rows for the inactive-dim styling
      rows.forEach((r) => r.classList.toggle('is-active', r === row));

      const newSlug = row.dataset.slug || null;

      // What image is currently visible? If we're mid cross-fade, it's the
      // current incomingSlug (which becomes the new outgoing). Otherwise it's
      // whichever image has .is-active.
      const currentActive = images.find((img) => img.classList.contains('is-active'));
      const currentVisibleSlug = incomingSlug ?? (currentActive?.dataset.previewImage ?? null);

      activeRow = row;

      // Measure the new target row and update the spring's destination
      const { y, h } = measureRow(row);
      state.targetY = y;
      state.targetH = h;

      // Set up cross-fade: start from current pill position, travel to new target
      outgoingSlug = currentVisibleSlug;
      incomingSlug = newSlug;
      transitionStartY = state.y;
      transitionDistance = Math.abs(state.targetY - transitionStartY);

      // Pre-position images for the fade: outgoing visible, incoming at 0
      images.forEach((img) => {
        if (img.dataset.previewImage === outgoingSlug) {
          img.style.opacity = '1';
          img.classList.add('is-active');
        } else if (img.dataset.previewImage === incomingSlug) {
          img.style.opacity = '0';
          img.classList.add('is-active');
        } else {
          img.style.opacity = '';
          img.classList.remove('is-active');
        }
      });

      ensureRaf();
    };

    list.addEventListener('pointermove', (e) => {
      const target = (e.target as HTMLElement).closest('[data-row]') as HTMLElement | null;
      if (!target) return;
      setActive(target);
    }, { passive: true });

    list.addEventListener('focusin', (e) => {
      const target = (e.target as HTMLElement).closest('[data-row]') as HTMLElement | null;
      if (target) setActive(target);
    });

    // ── Pill (rollover bar) visibility ──
    // The pill only shows while the pointer is within the list column. It
    // fades in from blur (like everything else); on leave it waits 1800ms
    // before fading back out. Driven by the --pill-visible custom property
    // (see global.css): the list gets .is-hovered while the pointer is inside.
    let pillHideTimer = 0;
    list.addEventListener('pointerenter', () => {
      clearTimeout(pillHideTimer);
      list.classList.add('is-hovered');
    });
    list.addEventListener('pointerleave', () => {
      clearTimeout(pillHideTimer);
      pillHideTimer = window.setTimeout(() => list.classList.remove('is-hovered'), 1800);
    });

    let resizeRaf = 0;
    window.addEventListener('resize', () => {
      cancelAnimationFrame(resizeRaf);
      resizeRaf = requestAnimationFrame(() => {
        if (activeRow) {
          const { y, h } = measureRow(activeRow);
          state.targetY = y;
          state.targetH = h;
          state.y = y; state.h = h;
          state.vy = 0; state.vh = 0;
          pill.style.transform = `translateY(${y}px)`;
          pill.style.height = `${h}px`;
        }
      });
    });
  }
</script>

<script>
  // ─────────────────────────────────────────────────────────
  // Inline transition: list → detail (same page, no navigation)
  // ─────────────────────────────────────────────────────────
  import { arcFlip, concert, easings, makeSpring } from '../lib/arc-flip';
  import { staggerOut, staggerIn } from '../lib/reveal';

  // Choreography props for the list → detail move. The title leads; the image
  // yields — trailing slightly and arcing downward so it never crosses the
  // title's path. Default easing is the organic SPRING from the menu rollover
  // (tokens 410/84/3). Live-editable via the TUNING panel below.
  const CHOREO_KEY = 'leroice-choreo';
  const DEFAULT_CHOREO = {
    leadIn: 0,          // ms: delay before the proximity cascade begins
    easing: 'gentle',   // soft-landing curve (smooth in, gentle settle)
    spring: { stiffness: 900, damping: 160, mass: 0.5 },
    title: { duration: 1000, delay: 0, arc: 0,   scale: false },
    image: { duration: 980,  delay: 0, arc: 0.1, minYield: 58, scale: true },
    // Proximity cascade when a row opens: nearest rows fade+blur out first.
    stagger: { step: 15, blur: 6, outDuration: 340 },
  };
  // Mutable runtime config — the TUNING panel writes here + to localStorage.
  const CHOREO = (() => {
    try {
      const saved = JSON.parse(localStorage.getItem(CHOREO_KEY) || 'null');
      if (saved) {
        return {
          leadIn: saved.leadIn ?? DEFAULT_CHOREO.leadIn,
          easing: saved.easing ?? DEFAULT_CHOREO.easing,
          spring: { ...DEFAULT_CHOREO.spring, ...(saved.spring || {}) },
          title: { ...DEFAULT_CHOREO.title, ...(saved.title || {}) },
          image: { ...DEFAULT_CHOREO.image, ...(saved.image || {}) },
          stagger: { ...DEFAULT_CHOREO.stagger, ...(saved.stagger || {}) },
        };
      }
    } catch { /* ignore bad storage */ }
    return JSON.parse(JSON.stringify(DEFAULT_CHOREO));
  })();
  const easingFor = () =>
    CHOREO.easing === 'spring'
      ? makeSpring(CHOREO.spring)
      : (easings[CHOREO.easing] || easings.expoOut);

  {
    const split = document.querySelector('.split') as HTMLElement;
    const list = document.querySelector('[data-list]') as HTMLElement;
    const rows = Array.from(document.querySelectorAll<HTMLElement>('[data-row]'));

    if (split && list && rows.length) {

      const BP_DESKTOP = 881;       // matches the CSS breakpoint where .preview shows

      let busy = false;             // a transition is animating
      let closing = false;          // a close is in progress (guards re-entrancy)
      let openRow: HTMLElement | null = null;
      let openDetail: HTMLElement | null = null;
      let activeAnims: Animation[] = [];
      // Token invalidates stale async callbacks (a close/new-open supersedes a
      // pending open finalize), so a late .then() can't clobber fresh state.
      let token = 0;

      const cancelActive = () => {
        for (const a of activeAnims) { try { a.cancel(); } catch { /* noop */ } }
        activeAnims = [];
      };
      const reducedMotion = () =>
        window.matchMedia('(prefers-reduced-motion: reduce)').matches;

      // ── OPEN ──
      function open(row: HTMLElement) {
        const slug = row.dataset.slug!;
        const detail = document.querySelector(
          `.list__detail[data-detail-slug="${slug}"]`
        ) as HTMLElement;
        if (!detail || busy || closing || openRow) return;
        busy = true;
        const myToken = ++token;

        const pw = document.querySelector('.list__pill-wrap') as HTMLElement | null;
        const previewFrame =
          document.querySelector('.preview__frame') as HTMLElement | null;
        const hero = detail.querySelector('.detail__hero') as HTMLElement | null;
        const back = detail.querySelector('.detail__back') as HTMLElement | null;
        const bodyText = detail.querySelector('.detail__body') as HTMLElement | null;
        const prefersReduced = reducedMotion();

        // Hide pill, freeze hover, and settle scroll so every rect we read —
        // now and after the collapse — shares one coordinate space.
        if (pw) { pw.style.transition = 'opacity 150ms'; pw.style.opacity = '0'; }
        list.style.pointerEvents = 'none';
        window.scrollTo({ top: 0, behavior: 'instant' });

        // FIRST rects, captured while everything is still in its list state.
        // (FLIP is meant to span the layout change: `from` is the pre-collapse
        // box, the post-collapse box is measured inside arcFlip.)
        const titleFirst = row.getBoundingClientRect();
        const imageFirst = previewFrame ? previewFrame.getBoundingClientRect() : null;

        // The other rows cascade OUT by proximity to the clicked row (nearest
        // fades+blurs first, rippling outward). The preview stays put — it
        // hands straight off to the hero so the image never blinks out.
        const others = rows.filter((r) => r !== row);

        const runCommit = () => {
          if (myToken !== token) return; // superseded before the lead-in fired

          // Commit the final layout. The title holds in place (transform →
          // flow); the preview is swapped for the hero at the same spot.
          split.classList.add('is-detail');
          for (const r of rows) {
            if (r !== row) r.style.display = 'none';
          }
          row.style.transition = '';
          row.style.transform = '';
          row.style.position = '';
          row.style.zIndex = '';
          row.classList.add('is-heading');

          detail.hidden = false;
          openRow = row;
          openDetail = detail;
          history.pushState({ slug }, '', `/work/${slug}`);

          const isMobile = window.innerWidth < BP_DESKTOP;
          const canFlip =
            !prefersReduced && !isMobile && hero && imageFirst && imageFirst.width > 0;

          if (!canFlip) {
            // Fallback (reduced motion, or mobile with no preview).
            list.style.pointerEvents = '';
            if (prefersReduced) { busy = false; return; } // instant
            detail.style.opacity = '0';
            detail.style.transition = 'opacity 320ms ease';
            requestAnimationFrame(() => { detail.style.opacity = '1'; });
            const onEnd = () => {
              detail.style.transition = '';
              detail.style.opacity = '';
              detail.removeEventListener('transitionend', onEnd);
              busy = false;
            };
            detail.addEventListener('transitionend', onEnd);
            setTimeout(onEnd, 420);
            return;
          }

          // The case-study content loads IN in sequence (fade + blur), behind
          // the image as it settles — nothing just appears.
          const bodyEls = [
            back,
            ...(bodyText ? (Array.from(bodyText.children) as HTMLElement[]) : []),
          ].filter(Boolean) as HTMLElement[];
          staggerIn(bodyEls, { baseDelay: 160, step: CHOREO.stagger.step, blur: CHOREO.stagger.blur });

          // Concerted move: the title rises (straight expo) while the image
          // FLIPs in from the preview pane, trailing slightly and arcing
          // DOWNWARD — yielding so the title can pass above without crossing.
          activeAnims = [
            arcFlip(row, titleFirst, { ...CHOREO.title, easing: easingFor() }),
            arcFlip(hero!, imageFirst!, { ...CHOREO.image, easing: easingFor() }),
          ];

          concert(activeAnims).then(() => {
            if (myToken !== token) return; // a close/open superseded us
            activeAnims = [];
            list.style.pointerEvents = ''; // restore hover only after the motion
            busy = false;
          });
        };

        // Run the proximity cascade, then move once the path is clear.
        if (prefersReduced) {
          for (const r of others) r.style.opacity = '0';
          runCommit();
        } else {
          staggerOut(others, {
            origin: row,
            baseDelay: CHOREO.leadIn,
            step: CHOREO.stagger.step,
            blur: CHOREO.stagger.blur,
            duration: CHOREO.stagger.outDuration,
          }).then(() => { if (myToken === token) runCommit(); });
        }
      }

      // ── CLOSE ── (also interrupts an in-flight open)
      function close() {
        if (!openDetail || !openRow || closing) return;
        closing = true;
        busy = true;
        ++token;                 // invalidate any pending open finalize
        const myToken = token;
        cancelActive();          // stop an in-flight open animation

        const row = openRow;
        const detail = openDetail;
        const pw = document.querySelector('.list__pill-wrap') as HTMLElement | null;
        const preview = document.querySelector('.preview') as HTMLElement | null;
        const prefersReduced = reducedMotion();

        list.style.pointerEvents = 'none';

        // The detail content fades + blurs out softly (rippling from the
        // heading), then the list cascades gently back in.
        const back = detail.querySelector('.detail__back') as HTMLElement | null;
        const bodyText = detail.querySelector('.detail__body') as HTMLElement | null;
        const hero = detail.querySelector('.detail__hero') as HTMLElement | null;
        const outEls = [
          hero,
          back,
          ...(bodyText ? (Array.from(bodyText.children) as HTMLElement[]) : []),
        ].filter(Boolean) as HTMLElement[];

        const restore = () => {
          if (myToken !== token) return; // superseded
          detail.hidden = true;
          for (const el of outEls) {
            el.style.transition = ''; el.style.opacity = ''; el.style.filter = ''; el.style.willChange = '';
          }

          split.classList.remove('is-detail');
          row.classList.remove('is-heading');
          row.style.cssText = '';
          for (const r of rows) {
            if (r !== row) r.style.cssText = '';
          }
          if (pw) { pw.style.transition = ''; pw.style.opacity = ''; }
          if (preview) { preview.style.transition = ''; preview.style.opacity = ''; }

          // Reset the pill's velocity-driven CSS vars to rest so it doesn't
          // snap from a stale value when the list returns.
          const docStyle = document.documentElement.style;
          docStyle.setProperty('--pill-velocity-blur', '0px');
          docStyle.setProperty('--pill-velocity-opacity', '0.06');

          openRow = null;
          openDetail = null;
          window.scrollTo({ top: 0, behavior: 'instant' });

          const done = () => {
            list.style.pointerEvents = '';
            closing = false;
            busy = false;
          };

          if (prefersReduced) { done(); return; }
          // Rows ripple back in from where the heading sat, landing gently.
          staggerIn(rows, {
            origin: row,
            step: CHOREO.stagger.step,
            blur: CHOREO.stagger.blur,
          }).then(done);
        };

        if (prefersReduced) { restore(); return; }
        staggerOut(outEls, {
          origin: row,
          step: CHOREO.stagger.step,
          blur: CHOREO.stagger.blur,
          duration: 260,
        }).then(restore);
      }

      // Expose the live transition state so the site-wide exit handler
      // (Base.astro) can defer to an in-flight open/close instead of layering
      // a conflicting page-exit cascade on the same elements.
      (window as any).__leroiceBusy = () => busy || closing;

      // ── listeners ──
      const tryOpen = (row: HTMLElement | null) => {
        if (!row) return;
        const s = row.dataset.slug;
        if (s && document.querySelector(`.list__detail[data-detail-slug="${s}"]`)) open(row);
      };

      list.addEventListener('click', (e) => {
        tryOpen((e.target as HTMLElement).closest<HTMLElement>('[data-row]'));
      });

      // Keyboard: Enter / Space on a focused inline row opens it (the inline
      // rows are <div>s, so they get role=button + tabindex in the template).
      list.addEventListener('keydown', (e) => {
        if (e.key !== 'Enter' && e.key !== ' ' && e.key !== 'Spacebar') return;
        const row = (e.target as HTMLElement).closest<HTMLElement>('[data-row]');
        if (!row || row.dataset.inline !== 'true') return;
        e.preventDefault();
        tryOpen(row);
      });

      document.addEventListener('click', (e) => {
        if ((e.target as HTMLElement).closest('[data-detail-back]')) history.back();
      });

      window.addEventListener('popstate', () => {
        if (openDetail) close();
      });

      // ── TUNING panel ──────────────────────────────────────
      const tuner = document.querySelector('[data-tuner]') as HTMLElement | null;
      const tunerToggle = document.querySelector('[data-tuner-toggle]') as HTMLElement | null;
      if (tuner && tunerToggle) {
        const cacna = rows.find((r) => r.dataset.slug === 'cacna-1a') || null;

        const fields = [
          { path: ['leadIn'],            id: 'leadIn', min: 0,   max: 400,  step: 10,   unit: 'ms' },
          { path: ['title', 'duration'], id: 'tdur',   min: 200, max: 1400, step: 20,   unit: 'ms' },
          { path: ['image', 'duration'], id: 'idur',   min: 200, max: 1400, step: 20,   unit: 'ms' },
          { path: ['image', 'delay'],    id: 'idelay', min: 0,   max: 400,  step: 10,   unit: 'ms' },
          { path: ['image', 'arc'],      id: 'iarc',   min: 0,   max: 1,    step: 0.05, unit: '' },
          { path: ['image', 'minYield'], id: 'iyield', min: 0,   max: 120,  step: 2,    unit: 'px' },
          { path: ['stagger', 'step'],   id: 'sgstep', min: 0,   max: 120,  step: 5,    unit: 'ms' },
          { path: ['stagger', 'blur'],   id: 'sgblur', min: 0,   max: 20,   step: 1,    unit: 'px' },
          { path: ['spring', 'stiffness'], id: 'sstiff', min: 40,  max: 900, step: 10,  unit: '' },
          { path: ['spring', 'damping'],   id: 'sdamp',  min: 4,   max: 160, step: 2,   unit: '' },
          { path: ['spring', 'mass'],      id: 'smass',  min: 0.5, max: 8,   step: 0.5, unit: '' },
        ];
        const getVal = (path: string[]) => path.reduce((o: any, k) => o[k], CHOREO);
        const setVal = (path: string[], v: number) => {
          let o: any = CHOREO;
          for (let i = 0; i < path.length - 1; i++) o = o[path[i]];
          o[path[path.length - 1]] = v;
        };
        const save = () => {
          try { localStorage.setItem(CHOREO_KEY, JSON.stringify(CHOREO)); } catch { /* ignore */ }
        };

        const statusEl = tuner.querySelector('[data-tune-status]') as HTMLElement | null;
        let flashTimer = 0;
        const flash = (msg: string) => {
          if (!statusEl) return;
          statusEl.textContent = msg;
          clearTimeout(flashTimer);
          flashTimer = window.setTimeout(() => { statusEl.textContent = ''; }, 1400);
        };

        const syncInputs = () => {
          for (const f of fields) {
            const input = tuner.querySelector(`#tune-${f.id}`) as HTMLInputElement | null;
            const out = tuner.querySelector(`#out-${f.id}`) as HTMLElement | null;
            if (input) input.value = String(getVal(f.path));
            if (out) out.textContent = getVal(f.path) + f.unit;
          }
          const sel = tuner.querySelector('#tune-easing') as HTMLSelectElement | null;
          if (sel) sel.value = CHOREO.easing;
          const grp = tuner.querySelector('[data-tuner-spring]') as HTMLElement | null;
          if (grp) grp.style.opacity = CHOREO.easing === 'spring' ? '1' : '0.35';
        };

        for (const f of fields) {
          const input = tuner.querySelector(`#tune-${f.id}`) as HTMLInputElement | null;
          const out = tuner.querySelector(`#out-${f.id}`) as HTMLElement | null;
          if (!input) continue;
          input.min = String(f.min); input.max = String(f.max); input.step = String(f.step);
          input.addEventListener('input', () => {
            const v = parseFloat(input.value);
            setVal(f.path, v);
            if (out) out.textContent = v + f.unit;
            save();
          });
        }

        const easeSel = tuner.querySelector('#tune-easing') as HTMLSelectElement | null;
        const springGroup = tuner.querySelector('[data-tuner-spring]') as HTMLElement | null;
        const updateSpringVisibility = () => {
          if (springGroup) springGroup.style.opacity = CHOREO.easing === 'spring' ? '1' : '0.35';
        };
        if (easeSel) {
          // Populate from the full easing library, with the organic spring first.
          const names = ['spring', ...Object.keys(easings)];
          easeSel.innerHTML = names
            .map((n) => `<option value="${n}">${n}</option>`)
            .join('');
          easeSel.addEventListener('change', () => {
            CHOREO.easing = easeSel.value;
            updateSpringVisibility();
            save();
          });
        }

        tunerToggle.addEventListener('click', () => {
          tuner.hidden = !tuner.hidden;
          tunerToggle.setAttribute('aria-expanded', String(!tuner.hidden));
        });

        tuner.querySelector('[data-tune-replay]')?.addEventListener('click', () => {
          if (!cacna) return;
          if (openDetail) { close(); window.setTimeout(() => open(cacna), 520); }
          else open(cacna);
        });

        tuner.querySelector('[data-tune-copy]')?.addEventListener('click', async () => {
          const c = CHOREO;
          const cfg =
            `const CHOREO = {\n` +
            `  leadIn: ${c.leadIn},\n` +
            `  easing: '${c.easing}',\n` +
            `  spring: { stiffness: ${c.spring.stiffness}, damping: ${c.spring.damping}, mass: ${c.spring.mass} },\n` +
            `  title: { duration: ${c.title.duration}, delay: ${c.title.delay}, arc: ${c.title.arc}, scale: ${c.title.scale} },\n` +
            `  image: { duration: ${c.image.duration}, delay: ${c.image.delay}, arc: ${c.image.arc}, minYield: ${c.image.minYield}, scale: ${c.image.scale} },\n` +
            `  stagger: { step: ${c.stagger.step}, blur: ${c.stagger.blur}, outDuration: ${c.stagger.outDuration} },\n` +
            `};`;
          try { await navigator.clipboard.writeText(cfg); flash('copied ✓'); }
          catch { flash('copy failed'); }
        });

        tuner.querySelector('[data-tune-reset]')?.addEventListener('click', () => {
          Object.assign(CHOREO, JSON.parse(JSON.stringify(DEFAULT_CHOREO)));
          try { localStorage.removeItem(CHOREO_KEY); } catch { /* ignore */ }
          syncInputs();
          flash('reset');
        });

        syncInputs();
      }
    }
  }
</script>

<style>
  /* TUNING panel — design tool for the list→detail choreography. */
  .tuner-toggle {
    position: fixed;
    right: 16px;
    bottom: 16px;
    z-index: 50;
    font-family: var(--font-sans);
    font-size: 11px;
    letter-spacing: 0.04em;
    padding: 8px 13px;
    border-radius: 999px;
    background: var(--text-primary);
    color: var(--bg);
    border: none;
    cursor: pointer;
    opacity: 0.5;
    transition: opacity 160ms ease;
  }
  .tuner-toggle:hover { opacity: 1; }

  .tuner {
    position: fixed;
    right: 16px;
    bottom: 56px;
    z-index: 50;
    width: 280px;
    max-width: calc(100vw - 32px);
    padding: 16px;
    border-radius: var(--radius-md);
    background: color-mix(in srgb, var(--bg) 85%, transparent);
    -webkit-backdrop-filter: blur(14px);
    backdrop-filter: blur(14px);
    border: 1px solid var(--rule);
    color: var(--text-primary);
    font-family: var(--font-sans);
    font-size: 11px;
    box-shadow: 0 16px 48px rgba(0, 0, 0, 0.2);
  }
  .tuner[hidden] { display: none; }

  .tuner__head {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: 14px;
    opacity: 0.7;
    letter-spacing: 0.02em;
  }
  .tuner__status { opacity: 0.6; }

  .tuner__grid { display: flex; flex-direction: column; gap: 11px; }
  .tuner__spring {
    display: flex;
    flex-direction: column;
    gap: 11px;
    margin-top: 12px;
    padding-top: 12px;
    border-top: 1px solid var(--rule);
    transition: opacity 160ms ease;
  }
  .tuner__sub { opacity: 0.5; letter-spacing: 0.02em; }
  .tuner label { display: flex; flex-direction: column; gap: 5px; opacity: 0.9; }
  .tuner__lab {
    display: flex;
    justify-content: space-between;
    align-items: baseline;
  }
  .tuner__lab output { opacity: 0.5; }
  .tuner input[type="range"] { width: 100%; accent-color: var(--text-primary); margin: 0; }
  .tuner select {
    font-family: inherit;
    font-size: 11px;
    padding: 5px 6px;
    background: transparent;
    color: var(--text-primary);
    border: 1px solid var(--rule);
    border-radius: 6px;
  }

  .tuner__actions { display: flex; gap: 8px; margin-top: 16px; }
  .tuner__actions button {
    flex: 1;
    font-family: inherit;
    font-size: 11px;
    padding: 7px 6px;
    border-radius: 8px;
    border: 1px solid var(--rule);
    background: transparent;
    color: var(--text-primary);
    cursor: pointer;
    opacity: 0.85;
    transition: opacity 160ms ease, background 160ms ease;
  }
  .tuner__actions button:hover { opacity: 1; background: var(--hover-bg); }

  @media (prefers-reduced-motion: reduce) {
    .tuner-toggle { transition: none; }
  }
</style>
